{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "AnimeQ",
    "version": "1.0.0",
    "identifier": "com.animeq.app",
    "build": {
        "frontendDist": "./frontend"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "title": "AnimeQ",
                "visible": true,
                "devtools": false
            }
        ]
    },
    "bundle": {
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}
